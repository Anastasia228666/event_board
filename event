package model;

import java.time.LocalDateTime;

public class Event {
    private int id;
    private String title;
    private LocalDateTime eventDate;
    private int maxSeats;
    private int freeSeats;

    public Event(int id, String title, LocalDateTime eventDate, int maxSeats) {
        this.id = id;
        this.title = title;
        this.eventDate = eventDate;
        this.maxSeats = maxSeats;
    }

    public void setEventDate(LocalDateTime eventDate) {
        this.eventDate = eventDate;
    }

    public void setId(int id) {
        this.id = id;
    }

    public void setMaxSeats(int maxSeats) {
        this.maxSeats = maxSeats;
    }

    public void setTitle(String title) {
        this.title = title;
    }

    public Event(int id, LocalDateTime eventDate, int freeSeats, int maxSeats, String title) {
        this.id = id;
        this.eventDate = eventDate;
        this.freeSeats = freeSeats;
        this.maxSeats = maxSeats;
        this.title = title;
    }

    public int getId() { return id; }
    public String getTitle() { return title; }
    public LocalDateTime getEventDate() { return eventDate; }
    public int getMaxSeats() { return maxSeats; }
    public int getFreeSeats() { return freeSeats; }
    public void setFreeSeats(int freeSeats) { this.freeSeats = freeSeats; }
}
